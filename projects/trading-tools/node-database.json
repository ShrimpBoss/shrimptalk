{
  "节点数据库说明": {
    "用途": "记录历史大节点的涨停/炸板数据，用于后续节点对比分析",
    "使用方法": "每日复盘后自动保存节点数据，遇到新节点时自动对比历史相似节点",
    "核心框架": "市场表现 = 情绪周期 + 题材 + 指数 共同呈现",
    "核心字段": {
      "最强题材": "涨停家数最多的题材，代表节点主线",
      "题材强度": "最强题材涨停家数/总涨停数，>30% 为强题材",
      "题材持续性": "该题材后续几天的表现",
      "涨停原因": "节点当日涨停的核心逻辑/消息面驱动",
      "情绪周期": "冰点/修复/回暖/加速/分歧/退潮",
      "指数状态": "新高/突破/震荡/下跌/冰点"
    }
  },
